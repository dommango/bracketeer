// Bracketeer data model.
//
// Designed so the WC2026 friend-group pool is a special case of a future
// multi-tenant platform: a Tournament holds its own structure + scoring config,
// Pools are leagues within a tournament, and nothing is WorldCup-hardcoded.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) — accounts, OAuth links, sessions, email magic-link tokens
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime  @default(now())
  // Prize-challenge consent: stamped once when the user first accepts the Terms /
  // Privacy / Official Rules and self-attests 18+ at challenge entry. Presence =
  // accepted; we keep timestamps (not a bool) for an auditable consent record.
  termsAcceptedAt DateTime?
  ageConfirmedAt  DateTime?
  // The name shown on the public Match Day Pickem leaderboard, when the user picks
  // one in account settings. Null => fall back to their account name (via publicLabel).
  challengeDisplayName String?

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  entries     Entry[]
  ownedPools  Pool[]        @relation("PoolOwner")
  messages    ChatMessage[]
  reactions   MessageReaction[]
  pushTokens  PushToken[]
  feedback    Feedback[]
}

// Native-app push registration. One row per device token; a token is globally
// unique (Apple/Google issue per-install), so re-registering the same token
// just refreshes ownership + lastSeenAt. Pruned when APNs reports it dead.
enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model PushToken {
  id         String         @id @default(cuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform @default(IOS)
  createdAt  DateTime       @default(now())
  lastSeenAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Tournament definition (generic; WC2026 is one seeded row)
// ---------------------------------------------------------------------------

model Tournament {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  sport            String           @default("football")
  startsAt         DateTime
  // Point values consumed by the scoring engine (groupExact, groupPartial, …).
  scoringConfig    Json
  // Optional structural metadata (round defs, labels) for generic tournaments.
  structure        Json?
  // Canonical answer key (a scoring Results object): admin-entered group
  // standings + third advancers + knockout winners + awards. Scoring runs each
  // entry against this. Result/Match rows hold live per-match scores for display
  // and feed this via manual entry or API propagation.
  officialResults  Json?
  createdAt        DateTime         @default(now())

  teams      Team[]
  matches    Match[]
  pools      Pool[]
  entries    Entry[]
  outrights        TeamOutright[]
  topScorers       TopScorer[]
  goalscorerOdds   GoalscorerOutright[]
  chatMessages     ChatMessage[]
}

model Team {
  id           String  @id @default(cuid())
  tournamentId String
  code         String // e.g. "MEX"
  name         String // e.g. "Mexico"
  group        String? // group letter A–L (null for non-group tournaments)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, code])
  @@index([tournamentId])
}

enum ResultStatus {
  SCHEDULED
  LIVE
  FINAL
}

enum ResultSource {
  API
  MANUAL
}

model Match {
  id           String   @id @default(cuid())
  tournamentId String
  // Internal match number the original tool keys on (group=1..72, R32=73..88,
  // R16=89..96, QF=97..100, SF=101..102, Bronze=103, Final=104).
  matchNo      Int
  roundCode    String // "GROUP" | "R32" | "R16" | "QF" | "SF" | "BRONZE" | "FINAL"
  // Bridge to the sports-API fixture id; null => manual-only.
  externalRef  String?
  scheduledAt  DateTime?
  // Slot descriptors for knockout feeders (e.g. "W73", "2A", "3rd:ABCDF").
  homeSlotRef  String?
  awaySlotRef  String?
  scored       Boolean  @default(false)
  venue        String?
  city         String?

  tournament Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  result     Result?
  events     MatchEvent[]
  stats      MatchStats?
  odds       MatchOdds?
  tickets    MatchTickets?
  prediction MatchPrediction?
  lineup     MatchLineup?
  injuries   MatchInjury?

  @@unique([tournamentId, matchNo])
  @@index([tournamentId])
  @@index([externalRef])
  @@index([tournamentId, scheduledAt])
}

model Result {
  id           String       @id @default(cuid())
  matchId      String       @unique
  homeTeamCode String?
  awayTeamCode String?
  homeScore    Int?
  awayScore    Int?
  homePens     Int?
  awayPens     Int?
  winnerCode   String?
  elapsed      Int?
  status       ResultStatus @default(SCHEDULED)
  source       ResultSource @default(MANUAL)
  updatedAt    DateTime     @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

enum EventType {
  GOAL
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISSED
  YELLOW_CARD
  RED_CARD
  YELLOW_RED_CARD
  SUBSTITUTION
}

model MatchEvent {
  id          String    @id @default(cuid())
  matchId     String
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  minute      Int
  extraMinute Int?
  type        EventType
  teamCode    String
  playerName  String?
  assistName  String?

  @@unique([matchId, minute, extraMinute, type, teamCode])
}

model MatchStats {
  id        String   @id @default(cuid())
  matchId   String   @unique
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  home      Json
  away      Json
  updatedAt DateTime @updatedAt
}

model MatchOdds {
  id          String   @id @default(cuid())
  matchId     String   @unique
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeWinProb Float
  drawProb    Float
  awayWinProb Float
  // Over/Under total-goals market (optional — populated by the slow-cadence extras
  // poll, independent of the h2h fields above). Null until a totals line is found.
  totalLine   Float? // the goals line, e.g. 2.5
  overProb    Float? // implied P(over) after stripping the two-way overround
  underProb   Float? // implied P(under)
  raw         Json     // raw decimal prices, for audit / re-derivation
  source      String   // "the-odds-api"
  fetchedAt   DateTime
}

// Tournament-winner futures (outrights): one row per team with the market's
// implied championship probability. Tournament-wide, not per-match — populated
// by the slow-cadence odds extras poll. Optional integration; absent = no data.
model TeamOutright {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamCode     String // internal 3-letter code
  winProb      Float // implied P(champion), normalized across all listed teams
  decimal      Float // raw decimal price, for audit / re-derivation
  source       String // "the-odds-api"
  fetchedAt    DateTime

  @@unique([tournamentId, teamCode])
}

// Top-goalscorer (Golden Boot) futures: per-player implied probability to finish
// the tournament's leading scorer. Tournament-wide, populated by the slow-cadence
// odds extras poll and replaced wholesale each run. Optional integration; absent =
// no data. Player names are the bookmaker's verbatim spelling (no internal id).
model GoalscorerOutright {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerName   String
  winProb      Float // implied P(top scorer), normalized across all listed players
  decimal      Float // raw decimal price, for audit / re-derivation
  source       String // "the-odds-api"
  fetchedAt    DateTime

  @@unique([tournamentId, playerName])
}

// Ticket availability per match. The event list + official buy link come from
// Ticketmaster Discovery; the lowest price is whatever the poller could find
// (Ticketmaster priceRanges when present, else an optional SeatGeek overlay).
// Optional integration — absent rows just mean no ticket info to show.
model MatchTickets {
  id          String   @id @default(cuid())
  matchId     String   @unique
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  minPrice    Float?
  currency    String?
  url         String? // official "buy tickets" link
  priceSource String? // where minPrice came from: "ticketmaster" | "seatgeek"
  source      String // event/link source: "ticketmaster"
  raw         Json?
  fetchedAt   DateTime
}

// Pre-match insights from API-Football's /predictions endpoint: model win %,
// an advice line, each side's recent form ("WWDLW"), and a head-to-head summary.
// One call covers all of it. Optional integration — absent = nothing to show.
model MatchPrediction {
  id          String   @id @default(cuid())
  matchId     String   @unique
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homePercent Float? // model-implied P(home win), 0–100
  drawPercent Float?
  awayPercent Float?
  advice      String? // e.g. "Double chance : Brazil or draw"
  homeForm    String? // last-5 form string, most recent last (e.g. "WWDLW")
  awayForm    String?
  h2h         Json? // compact { played, homeWins, awayWins, draws } summary
  raw         Json // full provider response, for audit / re-derivation
  fetchedAt   DateTime
}

// Starting XI + formation per team from API-Football's /fixtures/lineups endpoint
// (publishes ~1h before kickoff). home/away are player arrays ({ name, number, pos }).
// Optional integration — absent = no lineup to show.
model MatchLineup {
  id            String   @id @default(cuid())
  matchId       String   @unique
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeFormation String? // e.g. "4-3-3"
  awayFormation String?
  home          Json // [{ name, number, pos }] starting XI
  away          Json
  raw           Json // full provider response, for audit / re-derivation
  fetchedAt     DateTime
}

// Injured / suspended players per match from API-Football's /injuries endpoint.
// `players` is a flat [{ teamCode, playerName, type, reason }] list; the UI buckets
// it into the two sides by the match's resolved codes. Optional integration —
// absent = no squad-news to show.
model MatchInjury {
  id        String   @id @default(cuid())
  matchId   String   @unique
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  players   Json // [{ teamCode, playerName, type, reason }]
  raw       Json // full provider response, for audit / re-derivation
  fetchedAt DateTime
}

// Tournament top scorers (the Golden Boot race) from API-Football /players/topscorers.
// One cheap call returns the whole board; rows are replaced wholesale each poll.
// Optional integration — absent = nothing to show.
model TopScorer {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rank         Int // 1-based position in the goals ranking
  playerName   String
  teamCode     String // internal 3-letter code
  goals        Int
  assists      Int?
  appearances  Int?
  raw          Json
  fetchedAt    DateTime

  @@unique([tournamentId, rank])
}

// ---------------------------------------------------------------------------
// Pools (leagues) + entries + picks
// ---------------------------------------------------------------------------

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// The game a pool plays. FULL_BRACKET is the classic whole-tournament pool
// (imported picks, group + knockout). KNOCKOUT is the standalone knockout-stage
// challenge: picks are made once the 32 qualifiers are known and lock at the
// Round-of-32 kickoff.
enum PoolFormat {
  FULL_BRACKET
  KNOCKOUT
  // Match Day 3 Pickem: predict the scoreline of every final group-stage match
  // (the 24 round-3 games). Picks lock per-match at each fixture's kickoff and
  // score against the live Result rows — never against officialResults.
  MATCH_DAY_3_PICKEM
}

// Billing tier for a pool. FREE caps the member count; PREMIUM (a per-pool Stripe
// subscription) lifts the cap. Entitlements derive from this single field — see
// lib/billing/entitlements.ts — and the Stripe webhook is its only writer.
enum PoolTier {
  FREE
  PREMIUM
}

// The Bracketeer-sponsored public challenges that carry a prize. A subset of the
// PoolFormat values (full-bracket pools have no public challenge).
enum ChallengeKind {
  KNOCKOUT
  MATCH_DAY_3_PICKEM
}

// Lifecycle of a recorded prize award. PENDING = winner detected, awaiting manual
// gift-card fulfillment; REVIEW = a rank-1 tie an admin must resolve; SENT = card
// dispatched; SKIPPED = intentionally not awarded.
enum PrizeStatus {
  PENDING
  REVIEW
  SENT
  SKIPPED
}

model Pool {
  id           String     @id @default(cuid())
  tournamentId String
  name         String
  ownerId      String
  joinCode     String     @unique
  format       PoolFormat @default(FULL_BRACKET)
  tier         PoolTier   @default(FREE)
  // Stripe linkage for the pool's premium subscription (null until upgraded).
  stripeCustomerId     String?
  stripeSubscriptionId String?
  settings     Json?
  createdAt    DateTime   @default(now())

  tournament  Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  owner       User            @relation("PoolOwner", fields: [ownerId], references: [id])
  memberships Membership[]
  entries     Entry[]
  messages    ChatMessage[]
  snapshots   ScoreSnapshot[]
  invites     PoolInvite[]

  @@index([tournamentId])
}

// A tokenized invite to a pool, beyond the shareable join code. Optionally
// pre-addressed to an email (then sent via SMTP when configured) and optionally
// expiring. Single-use: accepting stamps acceptedAt/acceptedById and enrolls the
// user as a Membership (subject to the pool's member cap).
model PoolInvite {
  id           String     @id @default(cuid())
  poolId       String
  token        String     @unique
  email        String?
  role         MemberRole @default(MEMBER)
  createdById  String
  expiresAt    DateTime?
  acceptedAt   DateTime?
  acceptedById String?
  createdAt    DateTime   @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId])
}

model Membership {
  id          String     @id @default(cuid())
  poolId      String
  userId      String
  role        MemberRole @default(MEMBER)
  displayName String
  joinedAt    DateTime   @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId])
  @@index([poolId])
}

enum ImportSource {
  CSV
  UI
}

model Entry {
  id          String       @id @default(cuid())
  // The tournament this bracket scores against. Required and immutable — a
  // bracket always belongs to exactly one tournament, independent of any pool.
  tournamentId String
  // Zero-or-one pool. Nullable so a bracket can stand alone (built without a
  // pool) and be moved into / out of one later. SetNull on pool deletion keeps
  // the bracket (and its picks/score) alive as a standalone entry.
  poolId      String?
  // The game this bracket plays. Mirrors its pool's format when in one; set
  // explicitly for standalone brackets (the Challenge is KNOCKOUT-only).
  format      PoolFormat   @default(FULL_BRACKET)
  // Nullable until a real user claims this imported entry by email/displayName.
  userId      String?
  label       String
  // Email captured from the CSV contestant row, used for first-login claiming.
  claimEmail  String?
  locked      Boolean      @default(false)
  importedFrom ImportSource @default(CSV)
  tiebreak    String?
  // Opt-in flag for a solo bracket to appear on the public Bracketeer Knockout
  // Challenge leaderboard: true means the owner has entered it into the global
  // challenge. Default false (private — scored and visible only to the owner).
  // Knockout-only; irrelevant/harmless for full-bracket entries in ordinary pools.
  enteredChallenge Boolean @default(false)
  // Positional knockout picks: an AdvanceMap (matchNo -> "a"|"b") for brackets
  // built early against projected/placeholder seeds. The source of truth for
  // knockout winners on these entries — resolved to team codes against the live
  // seed for display and against the official seed at scoring time. Null for
  // full-bracket / CSV-imported / pre-feature entries (they score from Pick rows
  // as before). NOT part of the CSV/Pick mirror, so import/export are unchanged.
  knockoutAdvance Json?
  createdAt   DateTime     @default(now())

  tournament Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  pool      Pool?           @relation(fields: [poolId], references: [id], onDelete: SetNull)
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  picks     Pick[]
  breakdown ScoreBreakdown?
  snapshots ScoreSnapshot[]

  // A pool can hold MORE THAN ONE entry per user. A user owns every entry whose
  // claimEmail matches their account (bound on sign-in, see lib/auth/claim.ts),
  // and may keep several brackets. So idempotency/concurrency is guarded per
  // *bracket* — (pool, claimEmail, label) — not per user: two same-email
  // brackets with distinct labels coexist instead of overwriting each other,
  // and re-importing the same bracket still updates in place. NULLs are distinct
  // in Postgres, so email-less CSV entries are unaffected.
  @@unique([poolId, claimEmail, label])
  @@index([poolId])
  @@index([poolId, userId])
  @@index([tournamentId])
  @@index([claimEmail])
}

model Pick {
  id          String @id @default(cuid())
  entryId     String
  // Mirrors the long-format CSV columns 1:1 for passthrough import/export.
  section     String // "group_stage", "round_of_32", "third_place_advancers", …
  category    String // "Group A", "M73", "advancer", "award" — carries group/match key
  key         String // "1st", "winner_pick", "player_of_the_tournament", "slot_1"
  code        String // team code (may be empty for value-only picks)
  teamOrValue String // team name or free-text award value
  positionMeta Json?

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model ScoreBreakdown {
  id          String   @id @default(cuid())
  entryId     String   @unique
  totalPoints Int      @default(0)
  byCategory  Json // { group, thirds, r32, r16, qf, sf, final, awards }
  perPick     Json? // optional per-pick detail for insights
  computedAt  DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

// Point/rank history per entry, written on each changing recompute (deduped so
// unchanged standings don't accumulate rows). Powers movers, table-moves, and
// recap deltas. Not a scoring source of truth — derived from ScoreBreakdown.
model ScoreSnapshot {
  id          String   @id @default(cuid())
  poolId      String
  entryId     String
  totalPoints Int
  rank        Int
  capturedAt  DateTime @default(now())

  pool  Pool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([poolId, capturedAt])
  @@index([entryId, capturedAt])
}

enum ChatKind {
  USER
  SYSTEM // auto-posted match events (goals, cards, results); no author
}

enum AttachmentType {
  GIF
  IMAGE
}

model ChatMessage {
  id        String   @id @default(cuid())
  // A message is scoped to exactly ONE of: a pool (pool chat) or a tournament
  // (the global challenge chat shared by everyone in an active challenge). Both
  // are nullable so the same table, reactions, replies, and UI serve both; pool
  // queries always filter by poolId and challenge queries by tournamentId, so the
  // two scopes never bleed together.
  poolId    String?
  tournamentId String?
  userId    String? // null for SYSTEM messages
  kind      ChatKind @default(USER)
  body      String
  // Quoted-reply target; SetNull so deleting the parent leaves the reply intact.
  replyToId String?
  // GIF / image attachment (provider URL; no bytes stored here).
  attachmentUrl  String?
  attachmentType AttachmentType?
  // SYSTEM-message context for rich rendering: { matchNo, event, ... }.
  meta      Json?
  createdAt DateTime @default(now())

  pool       Pool?             @relation(fields: [poolId], references: [id], onDelete: Cascade)
  tournament Tournament?       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   ChatMessage?       @relation("ChatReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[]      @relation("ChatReply")
  reactions MessageReaction[]

  @@index([poolId, createdAt])
  @@index([tournamentId, createdAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One row per (message, user, emoji): toggling is an upsert/delete.
  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ---------------------------------------------------------------------------
// In-app feedback / bug reports — a floating widget anyone can submit. Stored
// here and (best-effort) mirrored to a Notion board; the user link is optional
// so anonymous submissions are kept too.
// ---------------------------------------------------------------------------

enum FeedbackType {
  BUG
  IDEA
  OTHER
}

model Feedback {
  id          String       @id @default(cuid())
  userId      String?
  type        FeedbackType @default(BUG)
  title       String
  description String?
  pageUrl     String?
  userAgent   String?
  userEmail   String?
  // Base64 data-URL screenshots (region snips). Kept in-row for the single-
  // instance MVP; the Notion mirror forwards only the text fields, not images.
  screenshots Json?
  // Back-link to the synced Notion card, when the integration is configured.
  notionUrl   String?
  createdAt   DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

// A recorded Bracketeer-sponsored prize for a public-challenge winner. Phase 1 is
// detect-and-record: the resolver (lib/challenge/prizes.ts) upserts one row per
// (challenge, tournament) when the challenge completes, notifies the winner, and
// an admin fulfills the gift card by hand (status PENDING → SENT). FKs are stored
// as plain ids (audit-style, no cascade) so the table is fully additive. entryId/
// userId are null when a rank-1 tie needs admin review (status REVIEW).
model PrizeAward {
  id           String        @id @default(cuid())
  challenge    ChallengeKind
  tournamentId String
  entryId      String?
  userId       String?
  rank         Int           @default(1)
  status       PrizeStatus   @default(PENDING)
  description  String
  amount       Int?
  currency     String        @default("USD")
  createdAt    DateTime      @default(now())
  sentAt       DateTime?
  // The admin email that marked the card sent.
  sentBy       String?

  // One award per challenge per tournament — makes the resolver idempotent.
  @@unique([challenge, tournamentId])
  @@index([status])
}

// Shared (cross-instance) fixed-window rate-limit counter. Replaces the in-process
// Map in lib/rate-limit.ts so per-key limits hold across horizontally-scaled web
// replicas. One row per (key, window); `expiresAt` bounds the window and lets a
// cheap sweep prune stale rows. Keyed by an arbitrary string (e.g. "chat:<userId>").
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}
