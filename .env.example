# Copy to .env and fill in. Local dev can leave OAuth/email/sports blank.
DATABASE_URL="postgresql://user:password@localhost:5432/bracketeer"
APP_BASE_URL="http://localhost:3000"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="change-me-at-least-32-characters-long"
AUTH_URL="http://localhost:3000"

# Google OAuth (blank => Google sign-in button hidden)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic-link SMTP, e.g. smtp://user:pass@smtp.host:587
# (blank => magic-link disabled; sign-in links are logged to the server console)
EMAIL_SERVER=""
EMAIL_FROM="Bracketeer <no-reply@bracketeer.app>"

# Shared secret guarding /api/cron/* routes (the Railway cron service sends it)
CRON_SECRET="change-me"

# Sports data API — API-Football style (blank => manual result entry only)
SPORTS_API_KEY=""
SPORTS_API_BASE="https://v3.football.api-sports.io"
